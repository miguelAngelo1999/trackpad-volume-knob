<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App icon -->
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>

    <!-- App identity -->
    <key>CFBundleName</key>
    <string>TrackpadVolumeKnob</string>

    <key>CFBundleDisplayName</key>
    <string>TrackpadVolumeKnob</string>

    <key>CFBundleIdentifier</key>
    <string>com.trackpadvolumeknob</string>

    <key>CFBundleVersion</key>
    <string>2</string>

    <key>CFBundleShortVersionString</key>
    <string>1.1.0</string>

    <key>CFBundleExecutable</key>
    <string>TrackpadVolumeKnob</string>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <!-- Menu bar only — no Dock icon -->
    <key>LSUIElement</key>
    <true/>

    <!-- Minimum macOS version -->
    <key>LSMinimumSystemVersion</key>
    <string>14.0</string>

    <!-- Accessibility permission usage description (shown in System Settings) -->
    <key>NSAccessibilityUsageDescription</key>
    <string>TrackpadVolumeKnob needs Accessibility access to observe trackpad rotation gestures system-wide and adjust your volume.</string>

    <!-- High-resolution display support -->
    <key>NSHighResolutionCapable</key>
    <true/>

    <!-- App Category -->
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.utilities</string>

    <!-- Human-readable copyright -->
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2026. MIT License.</string>

    <!-- Sparkle auto-updater configuration -->
    <key>SUFeedURL</key>
    <string>https://raw.githubusercontent.com/miguelAngelo1999/trackpad-volume-knob/main/appcast.xml</string>

    <key>SUPublicEDKey</key>
    <string>no+h6Cj0mErZMmde6ysSHZo6gZnADKWyrvRgUFSe/q0=</string>

    <!-- Enable automatic update checks (user can toggle in Settings) -->
    <key>SUEnableAutomaticChecks</key>
    <true/>

    <!-- Check interval: once per day (86400 seconds) -->
    <key>SUScheduledCheckInterval</key>
    <integer>86400</integer>
</dict>
</plist>
