    <item>
      <title>Version 1.0.0</title>
      <pubDate>Mon, 14 Jul 2026 12:00:00 +0000</pubDate>
      <sparkle:version>1</sparkle:version>
      <sparkle:shortVersionString>1.0.0</sparkle:shortVersionString>
      <sparkle:minimumSystemVersion>14.0</sparkle:minimumSystemVersion>
      <description><![CDATA[
        <h2>Initial Release</h2>
        <ul>
          <li>Two-finger rotation for volume and brightness control</li>
          <li>Post-lift fling momentum (DragCurve physics)</li>
          <li>Haptic trackpad feedback (Off / Light / Medium / Strong)</li>
          <li>Per-app exclusion list (22 presets)</li>
          <li>Modifier key to switch between volume and brightness</li>
          <li>External display brightness via DDC</li>
        </ul>
      ]]></description>
